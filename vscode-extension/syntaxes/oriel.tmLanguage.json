{
  "scopeName": "source.oriel",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.oriel",
          "match": "//.*$"
        },
        {
          "name": "comment.block.oriel",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.oriel",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.oriel",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.oriel",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.oriel",
          "match": "\\b(fn|let|var|return|if|else|while|for|in|true|false|none|and|or|match)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.oriel",
          "match": "\\b(Int|Float|Decimal|Boolean|String|Void|List|Map|Set)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.oriel",
          "match": "(?<=\\bfn\\s)[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "support.function.builtin.oriel",
          "match": "\\b(print|input|len|range|push|type_of|read_file|write_file|json_encode|json_decode)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.oriel",
          "match": "==|!=|<=|>=|->|[+\\-*/%=<>!]"
        }
      ]
    }
  }
}
